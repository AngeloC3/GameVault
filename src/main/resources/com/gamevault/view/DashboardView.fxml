<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.gamevault.controller.DashboardController"
      VBox.vgrow="ALWAYS" stylesheets="@../styles/main.css">

    <!-- Top bar -->
    <HBox styleClass="topbar" alignment="CENTER_LEFT">
        <Label text="Dashboard" styleClass="page-title"/>
    </HBox>

    <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true"
                style="-fx-background-color: transparent; -fx-background: transparent;
                        -fx-padding: 16 20 16 20;">
        <content>
            <VBox spacing="16">

                <!-- Stat cards row -->
                <HBox spacing="10">
                    <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                        <Label fx:id="totalGamesNum" text="0" styleClass="stat-number"/>
                        <Label text="Total games" styleClass="stat-label"/>
                    </VBox>
                    <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                        <Label fx:id="playingNum" text="0" styleClass="stat-number"/>
                        <Label text="Playing now" styleClass="stat-label"/>
                    </VBox>
                    <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                        <Label fx:id="completedNum" text="0" styleClass="stat-number"/>
                        <Label text="Completed" styleClass="stat-label"/>
                    </VBox>
                    <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                        <Label fx:id="avgRatingNum" text="—" styleClass="stat-number"/>
                        <Label text="Avg rating" styleClass="stat-label"/>
                    </VBox>
                    <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                        <Label fx:id="backlogNum" text="0" styleClass="stat-number"/>
                        <Label text="In backlog" styleClass="stat-label"/>
                    </VBox>
                </HBox>

                <!-- Bottom row: status breakdown + recently added -->
                <HBox spacing="12">

                    <!-- Status breakdown -->
                    <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="10">
                        <Label text="Status breakdown" styleClass="game-card-meta"
                               style="-fx-font-size: 12px;"/>
                        <VBox fx:id="statusBreakdown" spacing="8"/>
                    </VBox>

                    <!-- Recently added -->
                    <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="10">
                        <Label text="Recently added" styleClass="game-card-meta"
                               style="-fx-font-size: 12px;"/>
                        <VBox fx:id="recentList" spacing="8"/>
                    </VBox>

                    <!-- Top rated -->
                    <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="10">
                        <Label text="Your top rated" styleClass="game-card-meta"
                               style="-fx-font-size: 12px;"/>
                        <VBox fx:id="topRatedList" spacing="8"/>
                    </VBox>

                </HBox>

            </VBox>
        </content>
    </ScrollPane>

</VBox>